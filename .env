COMPOSE_PROJECT_NAME=nl-biomero
NL_BIOMERO_VERSION=1.6.0
BIOMERO_IMPORTER_VERSION=1.2.1
BIOMERO_VERSION=v2.6.0
OMERO_ZARR_PIXEL_BUFFER_VERSION=0.6.1
OMERO_FORMS_VERSION=2.2.0
OMERO_BIOMERO_VERSION=1.4.0
METABASE_SITE_URL=http://localhost:3000
METABASE_SECRET_KEY=1f8e2c8ae6450b1035fe5ac9219a8f34702ab3cb01b1c3c767cfb55922c1d881
METABASE_IMPORTS_DB_PAGE_DASHBOARD_ID=6
METABASE_WORKFLOWS_DB_PAGE_DASHBOARD_ID=2

# Enables the BIOMERO.importer frontend in OMERO.biomero
IMPORTER_ENABLED=TRUE
COMPOSE_PROFILES=IMPORTER_ENABLED
# To disable the BIOMERO.importer service, comment the above line and uncomment the following:
# IMPORTER_ENABLED=FALSE
# COMPOSE_PROFILES=adi_disabled

# Enables the BIOMERO.analyzer frontend in OMERO.biomero
ANALYZER_ENABLED=TRUE
# To disable the BIOMERO.analyzer service, comment the above line and uncomment the following:
# ANALYZER_ENABLED=FALSE
# COMPOSE_PROFILES=biomero_disabled

FORMS_MASTER_USER=formsadmin5
FORMS_MASTER_PASSWORD=changedpwagain3

# Database credentials
POSTGRES_USER=omero
POSTGRES_PASSWORD=omero
POSTGRES_DB=omero

BIOMERO_POSTGRES_USER=biomero
BIOMERO_POSTGRES_PASSWORD=biomero
BIOMERO_POSTGRES_DB=biomero

# OMERO credentials
OMERO_ROOT_PASSWORD=omero

# OMERO timeout and logging settings
OMERO_SCRIPTS_TIMEOUT=604800000
OMERO_SESSIONS_TIMEOUT=604800000
OMERO_WEB_SESSION_EXPIRE_AT_BROWSER_CLOSE=false
OMERO_WEB_SESSION_COOKIE_AGE=604800
OMERO_LOGGING_LEVEL=10

# OMERO web settings
OMERO_WEB_ENV=TEST
IMPORT_MOUNT_PATH=/data

# OMERO importer settings
OMERO_IMPORTER_USER=root
OMERO_PORT=4064
ADI_RUN_MIGRATIONS=1
OMERO_CONTAINER_USER=1000:1000

# Metabase credentials
