# Environment configuration for external OMERO connection
# Copy this file to .env and modify as needed for Scenario 3 deployments

# External OMERO server connection details
EXTERNAL_OMERO_HOST=your-omero-server.example.com
EXTERNAL_OMERO_PORT=4064
EXTERNAL_OMERO_USER=root
EXTERNAL_OMERO_PASSWORD=your-root-password

# BIOMERO database configuration
BIOMERO_POSTGRES_USER=biomero
BIOMERO_POSTGRES_DB=biomero
BIOMERO_POSTGRES_PASSWORD=change-me-for-production

# Metabase configuration
METABASE_USER=admin@example.com
METABASE_PASSWORD=change-me-for-production
METABASE_SITE_URL=http://localhost:3000
METABASE_SECRET_KEY=random-secret-key
METABASE_IMPORTS_DB_PAGE_DASHBOARD_ID=1
METABASE_WORKFLOWS_DB_PAGE_DASHBOARD_ID=2

# OMERO timeout and logging settings
OMERO_SCRIPTS_TIMEOUT=604800000
OMERO_SESSIONS_TIMEOUT=604800000
OMERO_LOGGING_LEVEL=10
OMERO_WEB_SESSION_EXPIRE_AT_BROWSER_CLOSE=false
OMERO_WEB_SESSION_COOKIE_AGE=604800

# OMERO web settings
OMERO_WEB_ENV=TEST
IMPORT_MOUNT_PATH=/data

# OMERO importer settings
OMERO_IMPORTER_USER=root
OMERO_PORT=4064
ADI_RUN_MIGRATIONS=1
OMERO_CONTAINER_USER=1000:1000

# NL-BIOMERO version
NL_BIOMERO_VERSION=latest
OMEROADI_VERSION=latest

# ADI configuration
ADI_ENABLED=true

# OMERO.forms configuration
FORMS_MASTER_USER=admin
FORMS_MASTER_PASSWORD=change-me-for-production
